# Gemini AI (bắt buộc để chấm CV)
GEMINI_API_KEY=your_gemini_api_key

# Email gửi đi (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Tuyển dụng <your@gmail.com>"

# Facebook Page (tuỳ chọn)
FB_PAGE_ID=your_page_id
FB_PAGE_ACCESS_TOKEN=your_long_lived_page_access_token

# Thông tin công ty (hiển thị trong form apply và email)
COMPANY_NAME=Tên Công Ty
COMPANY_CONTACT=0901234567
APP_URL=http://localhost:3002
